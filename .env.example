# RabbitMQ Learning Lab - environment variables template.
# Copy this file to `.env` before running `docker compose up` (`.env` itself
# is git-ignored, so real/local overrides never get committed):
#   cp .env.example .env
#
# The values below are safe defaults for local learning use only
# (guest/guest, admin/admin) - change them if you expose any port publicly.

# --- RabbitMQ ---
RABBITMQ_IMAGE_TAG=4.1-management
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_VHOST=/
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_METRICS_PORT=15692

# --- Prometheus / Grafana / Node Exporter ---
PROMETHEUS_IMAGE_TAG=v2.54.1
PROMETHEUS_PORT=9090

GRAFANA_IMAGE_TAG=11.1.0
GRAFANA_USER=admin
GRAFANA_PASS=admin
GRAFANA_PORT=3000

NODE_EXPORTER_IMAGE_TAG=v1.12.1
NODE_EXPORTER_PORT=9100

# --- Producer / Consumer defaults (can be overridden with -e) ---
PREFETCH_COUNT=5
MAX_RETRIES=3
FAILURE_RATE=0.15
PROCESSING_MIN_DELAY=0.5
PROCESSING_MAX_DELAY=2.0
